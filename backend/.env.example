# FamilySync Backend — Environment Variables
# Copy to .env and fill in your values

# Server
PORT=8080

# PostgreSQL
DB_DSN=postgres://postgres:yourpassword@localhost:5432/familysync?sslmode=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# JWT
JWT_SECRET=change_me_to_a_long_random_secret_string

# Audio file upload directory
UPLOAD_DIR=./uploads
